# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# 1. MongoDB Atlas (replace localhost)
# Get connection string from: https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/econexus_carbon?retryWrites=true&w=majority

# 2. Supabase Postgres (replace local PostgreSQL)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI, use pooler port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or use individual vars if not using DATABASE_URL:
# PG_HOST=db.[project-ref].supabase.co
# PG_PORT=5432
# PG_DATABASE=postgres
# PG_USER=postgres
# PG_PASSWORD=your_password

# 3. Redis – Upstash or other public cache (replace localhost)
# Get from: https://console.upstash.com → Redis → REST API / Connect → ioredis URL
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379
# Or for local Redis:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# External APIs
ELECTRICITYMAP_API_KEY=your_key
HERE_API_KEY=your_here_key
ORS_API_KEY=your_openrouteservice_key
OPENWEATHER_API_KEY=your_openweather_key

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# AI/ML Service (optional)
ML_API_URL=http://localhost:5000

# Email (optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_key

# File Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
